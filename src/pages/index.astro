---
import Layout from '../layouts/Layout.astro';

const title = '춘천웨딩드레스 웨딩마치 | 2회 피팅 · 드레스 120벌 · 미래웨딩홀 입점';
const description = '강원도 춘천 웨딩드레스 전문샵 웨딩마치. 드레스 대여부터 헤어·메이크업·도우미까지 원스톱 웨딩 서비스. 미래웨딩홀 1층 입점, 2회 피팅 시스템.';

const heroImages = [
  '/images/instagram/00.webp',
  '/images/instagram/03.webp',
  '/images/instagram/06.webp',
  '/images/instagram/09.webp',
];

const stats = [
  { number: '120+', label: '드레스 보유' },
  { number: '2회', label: '피팅 시스템' },
  { number: '5★', label: '신부 만족도' },
  { number: '7년+', label: '춘천 No.1' },
];

const features = [
  {
    icon: '👗',
    title: '드레스 120벌',
    desc: '국내외 다양한 스타일의 웨딩드레스 120벌 보유. 신상 정기 업데이트로 항상 최신 트렌드.',
    badge: 'Collection'
  },
  {
    icon: '✦',
    title: '2회 피팅 시스템',
    desc: '3개월 전 1차 피팅(3벌) + 1개월 전 2차 피팅(3벌). 타샵 차별화된 전문 피팅 서비스.',
    badge: 'Signature'
  },
  {
    icon: '💍',
    title: '원스톱 웨딩',
    desc: '드레스 대여 + 헤어·메이크업 + 도우미까지. 미래웨딩홀 1층 입점, 결혼식 당일 이동 없이.',
    badge: 'All-in-One'
  },
];

const reviews = [
  {
    text: '촬영보다 본식이 더 예뻤어요. 드레스 퀄리티가 정말 달랐고, 2회 피팅 덕분에 완벽한 드레스를 찾을 수 있었습니다.',
    name: '춘천 신부',
    date: '2025년 10월 결혼',
    img: '/images/instagram/01.webp'
  },
  {
    text: '미래웨딩홀 바로 아래에 있어서 결혼식 당일 너무 편리했어요. 헤어메이크업부터 도우미까지 모두 한번에 해결됐습니다.',
    name: '강원 신부',
    date: '2025년 5월 결혼',
    img: '/images/instagram/04.webp'
  },
  {
    text: '드레스가 너무 예뻐서 피팅하면서 눈물이 났어요. 직원분들이 너무 친절하게 도와주셨습니다.',
    name: '홍천 신부',
    date: '2025년 11월 결혼',
    img: '/images/instagram/07.webp'
  },
];
---
<Layout title={title} description={description}>

  <!-- 풀스크린 히어로 슬라이더 -->
  <section class='relative h-screen min-h-[600px] overflow-hidden'>
    {heroImages.map((src, i) => (
      <div class={`hero-slide absolute inset-0 ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img src={src} alt={`웨딩마치 드레스 ${i+1}`}
          class='w-full h-full object-cover object-center'
          loading={i === 0 ? 'eager' : 'lazy'} />
        <div class='absolute inset-0' style='background: linear-gradient(to bottom, rgba(26,16,8,0.3) 0%, rgba(26,16,8,0.1) 40%, rgba(26,16,8,0.65) 100%);'></div>
      </div>
    ))}

    <!-- 히어로 텍스트 -->
    <div class='absolute bottom-0 left-0 right-0 px-8 pb-24 md:pb-28'>
      <div class='max-w-6xl mx-auto'>
        <p class='text-white/60 text-xs tracking-[0.5em] uppercase mb-4 font-light'>Chuncheon Bridal Salon</p>
        <h1 class='font-display text-5xl md:text-7xl lg:text-8xl text-white font-light tracking-wider leading-none mb-4'>
          Wedding<br/>
          <em class='not-italic font-light' style='color: #F7E7CE;'>March</em>
        </h1>
        <p class='text-white/75 text-lg md:text-xl font-light mb-8 max-w-md'>촬영보다 본식이 더 예뻤어요</p>
        <div class='flex flex-col sm:flex-row gap-4'>
          <a href='/contact'
             class='inline-block border-2 border-white text-white px-10 py-4 text-sm tracking-[0.2em] uppercase font-light hover:bg-white hover:text-[#8B3A47] transition-all duration-300'>
            피팅 예약하기
          </a>
          <a href='/gallery'
             class='inline-block text-white/70 px-10 py-4 text-sm tracking-[0.2em] uppercase font-light hover:text-white transition-colors border border-white/30 hover:border-white/60'>
            드레스 보러가기
          </a>
        </div>
      </div>
    </div>

    <!-- 슬라이더 인디케이터 -->
    <div class='absolute bottom-8 right-8 flex gap-2' id='slide-indicators'>
      {heroImages.map((_, i) => (
        <button
          class={`slide-dot rounded-full transition-all duration-300 h-2 ${i === 0 ? 'bg-white w-6' : 'bg-white/40 w-2'}`}
          data-slide={i}
          aria-label={`슬라이드 ${i+1}`}></button>
      ))}
    </div>

    <!-- 스크롤 유도 -->
    <div class='absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-1 text-white/40'>
      <span class='text-xs tracking-[0.3em] uppercase'>Scroll</span>
      <div class='w-px h-8 bg-white/30 animate-pulse'></div>
    </div>
  </section>

  <!-- 숫자 스탯 -->
  <section class='py-12 border-b border-[#E8DDD5]' style='background: #F7E7CE;'>
    <div class='max-w-5xl mx-auto px-6'>
      <div class='grid grid-cols-2 md:grid-cols-4 gap-8 text-center'>
        {stats.map((stat) => (
          <div class='group'>
            <p class='font-display text-4xl md:text-5xl font-light text-[#8B3A47] mb-1 group-hover:scale-105 transition-transform duration-300'>{stat.number}</p>
            <p class='text-xs tracking-[0.25em] text-[#B76E79] uppercase font-light'>{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 브랜드 특징 -->
  <section class='py-24 px-6' style='background: #FAF8F5;'>
    <div class='max-w-6xl mx-auto'>
      <div class='text-center mb-16'>
        <p class='text-xs tracking-[0.5em] text-[#B76E79] uppercase font-light mb-4'>Why Wedding March</p>
        <h2 class='font-display text-4xl md:text-5xl font-light text-gray-900 mb-4'>왜 웨딩마치인가요?</h2>
        <div class='w-12 h-px bg-[#B76E79] mx-auto mb-4'></div>
        <p class='text-gray-500 font-light text-sm'>춘천 신부들이 웨딩마치를 선택하는 이유</p>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
        {features.map((feat) => (
          <div class='group relative bg-white border border-[#E8DDD5] p-10 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 overflow-hidden'>
            <span class='absolute top-5 right-5 text-[10px] tracking-[0.3em] text-[#B76E79] uppercase border border-[#D4A0A7] px-2 py-0.5'>{feat.badge}</span>
            <div class='text-3xl mb-5 opacity-60'>{feat.icon}</div>
            <div class='w-8 h-px bg-[#B76E79] mb-5'></div>
            <h3 class='font-display text-2xl font-light text-gray-900 mb-4'>{feat.title}</h3>
            <p class='text-gray-500 text-sm leading-relaxed font-light'>{feat.desc}</p>
            <div class='absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#B76E79] to-[#D4A0A7] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left'></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 갤러리 섹션 -->
  <section class='py-20' style='background: #1a1008;'>
    <div class='max-w-6xl mx-auto px-6 mb-10'>
      <div class='flex items-end justify-between'>
        <div>
          <p class='text-xs tracking-[0.5em] text-[#D4A0A7] uppercase font-light mb-3'>Our Collection</p>
          <h2 class='font-display text-4xl md:text-5xl font-light text-white'>드레스 갤러리</h2>
        </div>
        <a href='/gallery' class='hidden md:inline-block text-[#D4A0A7] text-xs tracking-[0.3em] uppercase border-b border-[#D4A0A7] pb-0.5 hover:text-white hover:border-white transition-colors'>
          전체 보기 →
        </a>
      </div>
    </div>
    <div class='grid grid-cols-2 md:grid-cols-4 gap-px' style='background: #1a1008;'>
      <div class='col-span-2 overflow-hidden group relative' style='height: 380px;'>
        <img src='/images/instagram/02.webp' alt='웨딩마치 대표 드레스' class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105' />
        <div class='absolute inset-0 bg-black/0 group-hover:bg-black/15 transition-colors duration-500'></div>
      </div>
      {[
        { src: '/images/instagram/05.webp', alt: '슬림핏 드레스' },
        { src: '/images/instagram/08.webp', alt: '볼가운 드레스' },
        { src: '/images/instagram/01.webp', alt: '미니멀 드레스' },
        { src: '/images/instagram/04.webp', alt: '에이라인 드레스' },
      ].map((img) => (
        <div class='aspect-square overflow-hidden group relative'>
          <img src={img.src} alt={img.alt} class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-110' loading='lazy' />
          <div class='absolute inset-0 bg-black/0 group-hover:bg-black/15 transition-colors duration-500'></div>
        </div>
      ))}
    </div>
    <div class='text-center mt-10 px-6'>
      <a href='/gallery'
         class='inline-block border border-[#D4A0A7] text-[#D4A0A7] px-12 py-4 text-xs tracking-[0.3em] uppercase font-light hover:bg-[#D4A0A7] hover:text-[#1a1008] transition-all duration-300'>
        전체 갤러리 보기
      </a>
    </div>
  </section>

  <!-- 봄 시즌 배너 -->
  <section class='py-16 px-6 relative overflow-hidden text-center' style='background: #B76E79;'>
    <div class='absolute top-0 left-0 w-64 h-64 rounded-full opacity-10 -translate-x-32 -translate-y-32' style='background: #FAF8F5;'></div>
    <div class='absolute bottom-0 right-0 w-96 h-96 rounded-full opacity-10 translate-x-48 translate-y-48' style='background: #FAF8F5;'></div>
    <div class='max-w-4xl mx-auto relative'>
      <p class='text-white/70 text-xs tracking-[0.5em] uppercase font-light mb-4'>2026 Spring Season</p>
      <h2 class='font-display text-4xl md:text-5xl font-light text-white mb-4'>봄 성수기 특별 프로모션</h2>
      <div class='w-12 h-px bg-white/40 mx-auto mb-6'></div>
      <p class='text-white/80 font-light text-lg mb-8'>
        4~6월 성수기 피팅 날짜가 빠르게 마감되고 있습니다.<br/>
        원하는 날짜를 미리 확보하세요.
      </p>
      <div class='flex flex-col sm:flex-row gap-4 justify-center'>
        <a href='/contact'
           class='inline-block bg-white text-[#8B3A47] px-12 py-4 text-sm tracking-[0.2em] uppercase font-medium hover:bg-[#FAF8F5] transition-colors shadow-lg'>
          지금 예약하기
        </a>
        <a href='/packages'
           class='inline-block border border-white/50 text-white px-12 py-4 text-sm tracking-[0.2em] uppercase font-light hover:bg-white/10 transition-colors'>
          패키지 보기
        </a>
      </div>
    </div>
  </section>

  <!-- 신부 후기 -->
  <section class='py-24 px-6' style='background: #FAF8F5;'>
    <div class='max-w-6xl mx-auto'>
      <div class='text-center mb-16'>
        <p class='text-xs tracking-[0.5em] text-[#B76E79] uppercase font-light mb-4'>Bride Reviews</p>
        <h2 class='font-display text-4xl md:text-5xl font-light text-gray-900 mb-4'>신부들의 이야기</h2>
        <div class='w-12 h-px bg-[#B76E79] mx-auto'></div>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
        {reviews.map((review) => (
          <div class='bg-white border border-[#E8DDD5] p-8 relative group hover:shadow-xl transition-all duration-500'>
            <div class='font-display text-6xl text-[#D4A0A7]/30 leading-none mb-4 font-light'>"</div>
            <div class='w-16 h-16 rounded-full overflow-hidden mb-5 border-2 border-[#D4A0A7]'>
              <img src={review.img} alt='신부 후기' class='w-full h-full object-cover' loading='lazy' />
            </div>
            <div class='flex gap-0.5 mb-4'>
              {[1,2,3,4,5].map(() => <span class='text-[#B76E79] text-sm'>★</span>)}
            </div>
            <p class='text-gray-600 text-sm leading-relaxed mb-5 font-light italic'>"{review.text}"</p>
            <div class='border-t border-[#E8DDD5] pt-4'>
              <p class='text-[#B76E79] text-xs tracking-wider font-medium'>{review.name}</p>
              <p class='text-gray-400 text-xs mt-0.5'>{review.date}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 인스타그램 스트립 (10장 전부) -->
  <section class='py-16 px-6 border-t border-[#E8DDD5]' style='background: #FAF8F5;'>
    <div class='max-w-6xl mx-auto'>
      <div class='flex items-center justify-between mb-8'>
        <div class='flex items-center gap-3'>
          <svg class='w-5 h-5 text-[#B76E79]' fill='currentColor' viewBox='0 0 24 24'>
            <path d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z'/>
          </svg>
          <p class='text-sm font-medium text-gray-700'>@ch_weddingmarch</p>
        </div>
        <a href='https://www.instagram.com/ch_weddingmarch/' target='_blank' rel='noopener'
           class='text-xs tracking-[0.3em] text-[#B76E79] uppercase border-b border-[#B76E79] pb-0.5 hover:text-[#8B3A47] hover:border-[#8B3A47] transition-colors'>
          팔로우 →
        </a>
      </div>
      <div class='grid grid-cols-5 md:grid-cols-10 gap-1'>
        {['00','01','02','03','04','05','06','07','08','09'].map((n) => (
          <a href='https://www.instagram.com/ch_weddingmarch/' target='_blank' rel='noopener'
             class='aspect-square overflow-hidden group relative'>
            <img src={`/images/instagram/${n}.webp`} alt='웨딩마치 인스타그램'
              class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-110' loading='lazy' />
            <div class='absolute inset-0 bg-[#B76E79]/0 group-hover:bg-[#B76E79]/30 transition-colors duration-300 flex items-center justify-center'>
              <svg class='w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300' fill='currentColor' viewBox='0 0 24 24'>
                <path d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z'/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 최종 CTA -->
  <section class='py-24 px-6 text-center' style='background: #FAF8F5;'>
    <p class='text-xs tracking-[0.5em] text-[#B76E79] uppercase font-light mb-5'>Start Your Journey</p>
    <h2 class='font-display text-4xl md:text-6xl font-light text-gray-900 mb-6'>
      당신의 특별한 날,<br/>
      <span style='color: #B76E79; font-style: italic;'>웨딩마치와 함께</span>
    </h2>
    <div class='w-12 h-px bg-[#B76E79] mx-auto mb-8'></div>
    <p class='text-gray-500 font-light mb-10 text-lg'>
      춘천 최고의 웨딩드레스 전문샵에서<br/>
      평생 기억될 드레스를 만나보세요.
    </p>
    <a href='/contact'
       class='inline-block bg-[#B76E79] text-white px-16 py-5 text-sm tracking-[0.3em] uppercase font-light hover:bg-[#8B3A47] transition-all duration-300 shadow-xl'>
      무료 상담 예약하기
    </a>
  </section>

</Layout>

<script>
  // 히어로 슬라이더
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots = document.querySelectorAll<HTMLElement>('.slide-dot');
  let current = 0;

  function goToSlide(n: number) {
    slides[current].classList.remove('active');
    dots[current].style.width = '8px';
    dots[current].classList.add('bg-white/40');
    dots[current].classList.remove('bg-white');

    current = n;

    slides[current].classList.add('active');
    dots[current].style.width = '24px';
    dots[current].classList.remove('bg-white/40');
    dots[current].classList.add('bg-white');
  }

  let timer = setInterval(() => goToSlide((current + 1) % slides.length), 5000);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goToSlide(i);
      timer = setInterval(() => goToSlide((current + 1) % slides.length), 5000);
    });
  });
</script>
