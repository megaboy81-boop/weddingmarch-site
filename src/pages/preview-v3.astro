<!-- ══════════ JAVASCRIPT ══════════ -->
<script>
  // 1. Page load animation
  document.addEventListener('DOMContentLoaded', () => {
    // Stagger title words
    const words = document.querySelectorAll('.qh-title-word-inner');
    words.forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${0.1 + i * 0.08}s`;
    });

    // Trigger is-ready
    requestAnimationFrame(() => {
      setTimeout(() => {
        document.body.classList.add('is-ready');
      }, 100);
    });
  });

  // 2. Mobile menu toggle
  const menuBtn = document.getElementById('qhMenuBtn');
  const closeBtn = document.getElementById('qhMobileClose');
  const mobileNav = document.getElementById('qhMobileNav');

  menuBtn?.addEventListener('click', () => {
    mobileNav?.classList.add('is-open');
    if (menuBtn) menuBtn.textContent = 'Close';
  });
  closeBtn?.addEventListener('click', () => {
    mobileNav?.classList.remove('is-open');
    if (menuBtn) menuBtn.textContent = 'Menu';
  });

  // 3. Parallax bg on scroll
  const bg = document.querySelector('.qh-bg img') as HTMLImageElement;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (bg && scrollY < window.innerHeight * 2) {
      bg.style.transform = `translateY(${scrollY * 0.2}px)`;
    }
  }, { passive: true });

  // 4. Nav background on scroll
  const nav = document.querySelector('.qh-nav') as HTMLElement;
  window.addEventListener('scroll', () => {
    if (window.scrollY > window.innerHeight * 0.8) {
      nav?.style.setProperty('color', '#111');
    } else {
      nav?.style.setProperty('color', '#fff');
    }
  }, { passive: true });

  // 5. Table row hover: show thumbnail (already CSS-based)
  // 6. Title scramble effect on hover (lightweight version)
  const titleWords = document.querySelectorAll('.qh-title-word-inner');
  titleWords.forEach(el => {
    const original = el.textContent || '';
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ웨딩마치춘천';
    let interval: ReturnType<typeof setInterval> | null = null;
    let iteration = 0;

    el.closest('.qh-title-word')?.addEventListener('mouseenter', () => {
      iteration = 0;
      clearInterval(interval!);
      interval = setInterval(() => {
        (el as HTMLElement).textContent = original
          .split('')
          .map((letter, idx) => {
            if (idx < iteration) return original[idx];
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join('');
        if (iteration >= original.length) clearInterval(interval!);
        iteration += 1 / 3;
      }, 30);
    });

    el.closest('.qh-title-word')?.addEventListener('mouseleave', () => {
      clearInterval(interval!);
      (el as HTMLElement).textContent = original;
    });
  });
</script>

