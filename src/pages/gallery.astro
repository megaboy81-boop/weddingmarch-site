      const fname = ALL_FILES[i];
      const style = STYLES[i % STYLES.length];
      const div = document.createElement('div');
      div.className = 'gal-item';
      div.dataset.style = style;
      div.dataset.index = String(i);
      if (currentFilter !== '전체' && style !== currentFilter) div.classList.add('hidden');
      const img = document.createElement('img');
      img.src = `${BASE}/images/instagram/${fname}`;
      img.alt = `웨딩마치 ${style}`;
      img.loading = 'lazy';
      img.decoding = 'async';
      const overlay = document.createElement('div');
      overlay.className = 'gal-overlay';
      overlay.innerHTML = `<span>${style}</span>`;
      div.appendChild(img);
      div.appendChild(overlay);
      div.addEventListener('click', () => openLb(i));
      frag.appendChild(div);
    }
    grid.appendChild(frag);
    loaded = end;
    isLoading = false;
  }

  // Intersection Observer
  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) addBatch();
  }, { rootMargin: '500px' }).observe(sentinel);

  // 초기 클릭 이벤트
  document.querySelectorAll<HTMLElement>('.gal-item').forEach(item => {
    const idx = parseInt(item.dataset.index || '0');
    item.addEventListener('click', () => openLb(idx));
  });

  // ── 필터 ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.dataset.filter || '전체';
      document.querySelectorAll<HTMLElement>('.gal-item').forEach(item => {
        const show = currentFilter === '전체' || item.dataset.style === currentFilter;
        item.classList.toggle('hidden', !show);
      });
    });
  });

  // ── 라이트박스 ────────────────────────────────────────────────────
  function openLb(index: number) {
    lbIndex = index;
    lbImg.src = `${BASE}/images/instagram/${ALL_FILES[index]}`;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLb() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
    lbImg.src = '';
  }
  document.getElementById('lb-close')!.addEventListener('click', closeLb);
  document.getElementById('lb-prev')!.addEventListener('click', () => {
    lbIndex = (lbIndex - 1 + ALL_FILES.length) % ALL_FILES.length;
    lbImg.src = `${BASE}/images/instagram/${ALL_FILES[lbIndex]}`;
  });
  document.getElementById('lb-next')!.addEventListener('click', () => {
    lbIndex = (lbIndex + 1) % ALL_FILES.length;
    lbImg.src = `${BASE}/images/instagram/${ALL_FILES[lbIndex]}`;
  });
  lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') document.getElementById('lb-prev')!.click();
    if (e.key === 'ArrowRight') document.getElementById('lb-next')!.click();
  });
</script>

</Layout>
