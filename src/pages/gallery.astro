<script>
  // base URL 감지
  const BASE = (() => {
    const p = window.location.pathname;
    const m = p.match(/^(\/[^\/]+)\/gallery/);
    return m ? m[1] : '';
  })();

  const gm = (window as any).__GM__;
  const ALL_FILES: string[] = gm.files;
  const STYLES = ['에이라인', '볼가운', '슬림핏', '미니멀', '레이스'];
  const BATCH = 48;
  let loaded = 48;
  let currentFilter = '전체';
  let isLoading = false;
  let lbIndex = 0;

  const grid = document.getElementById('gal-grid')!;
  const sentinel = document.getElementById('load-sentinel')!;
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;

  // ── 배치 추가 ────────────────────────────────────────────────────
  function addBatch() {
    if (isLoading || loaded >= ALL_FILES.length) {
      if (loaded >= ALL_FILES.length) {
        sentinel.innerHTML = `<span style="font-size:11px;letter-spacing:0.3em;color:rgba(212,175,117,0.3);">— 전체 ${ALL_FILES.length.toLocaleString()}장 로드 완료 —</span>`;
