---
<Layout title={title} description={description}>

<style>
  body { background: #0D0608; }
  .gal-header { padding: 120px 8vw 60px; text-align: center; }
  .gal-filter { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 56px; }
  .filter-btn {
    padding: 9px 22px; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase;
    border: 1px solid rgba(212,175,117,0.3); color: rgba(255,255,255,0.5);
    background: transparent; cursor: pointer; transition: all 0.3s; font-family: inherit;
  }
  .filter-btn.active, .filter-btn:hover { border-color: #D4AF75; color: #D4AF75; }
  .gal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 3px; padding: 0 3px 3px;
  }
  .gal-item {
    position: relative; aspect-ratio: 3/4; overflow: hidden; cursor: pointer;
    background: #1a0e12;
  }
  .gal-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.23,1,0.32,1); display: block;
  }
  .gal-item:hover img { transform: scale(1.07); }
  .gal-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(7,3,5,0.75) 0%, transparent 50%);
    opacity: 0; transition: opacity 0.4s;
    display: flex; align-items: flex-end; padding: 16px;
  }
  .gal-overlay span { font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.8); }
  .gal-item:hover .gal-overlay { opacity: 1; }
  .gal-item.hidden { display: none; }
  #load-sentinel {
    height: 80px; display: flex; align-items: center; justify-content: center;
    padding: 20px;
  }
  .spinner {
    width: 24px; height: 24px; border: 1px solid rgba(212,175,117,0.2);
    border-top-color: #D4AF75; border-radius: 50%; animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  #lightbox {
    position: fixed; inset: 0; background: rgba(7,3,5,0.95);
    z-index: 1000; display: none; align-items: center; justify-content: center;
    backdrop-filter: blur(8px);
  }
  #lightbox.open { display: flex; }
  #lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; }
  #lb-close {
    position: absolute; top: 24px; right: 28px; color: rgba(255,255,255,0.6);
    font-size: 28px; cursor: pointer; background: none; border: none;
    transition: color 0.2s;
  }
  #lb-close:hover { color: white; }
  #lb-prev, #lb-next {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7); font-size: 22px; width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.3s;
  }
  #lb-prev { left: 20px; }
  #lb-next { right: 20px; }
  #lb-prev:hover, #lb-next:hover { background: rgba(212,175,117,0.15); color: #D4AF75; }
  @media (max-width: 640px) {
    .gal-grid { grid-template-columns: repeat(2, 1fr); gap: 2px; }
    #lb-prev { left: 8px; } #lb-next { right: 8px; }
  }
</style>

<!-- 헤더 -->
<section class="gal-header">
  <span class="section-label" style="color:rgba(212,175,117,0.7);">드레스 갤러리</span>
  <h1 class="font-display" style="font-size:clamp(40px,7vw,80px);font-weight:300;color:white;letter-spacing:0.04em;margin-bottom:12px;">Our Collection</h1>
  <p style="color:rgba(255,255,255,0.4);font-size:13px;letter-spacing:0.15em;">총 <span>1,472</span>장</p>
</section>

<!-- 필터 -->
<div class="gal-filter">
  <button class="filter-btn active" data-filter="전체">전체</button>
  <button class="filter-btn" data-filter="에이라인">에이라인</button>
  <button class="filter-btn" data-filter="볼가운">볼가운</button>
  <button class="filter-btn" data-filter="슬림핏">슬림핏</button>
  <button class="filter-btn" data-filter="미니멀">미니멀</button>
  <button class="filter-btn" data-filter="레이스">레이스</button>
</div>

<!-- 갤러리 그리드 (초기 48장 빌드타임 렌더링) -->
<div class="gal-grid" id="gal-grid">
  {initialImages.map((item, i) => (
    <div class="gal-item" data-style={item.style} data-index={i}>
      <img src={`${base}/images/instagram/${item.src}`} alt={`웨딩마치 ${item.style}`} loading="lazy" decoding="async" />
      <div class="gal-overlay"><span>{item.style}</span></div>
    </div>
  ))}
</div>

<!-- 무한스크롤 센티넬 -->
<div id="load-sentinel"><div class="spinner"></div></div>

<!-- 라이트박스 -->
<div id="lightbox">
  <button id="lb-close">✕</button>
  <button id="lb-prev">‹</button>
  <img id="lb-img" src="" alt="" />
  <button id="lb-next">›</button>
</div>

