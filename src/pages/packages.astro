---
import Layout from '../layouts/Layout.astro';

const title = '패키지 · 가격 | 웨딩마치 춘천 웨딩드레스';
const description = '춘천 웨딩마치 웨딩 패키지 가격표. 드레스 대여, 헤어·메이크업, 도우미 서비스. 강원도 춘천 웨딩 원스톱 서비스.';

const packages = [
  {
    name: '드레스 패키지',
    badge: '기본',
    color: 'border-gray-200',
    badgeColor: 'bg-gray-100 text-gray-600',
    price: '문의',
    unit: '',
    features: [
      '웨딩드레스 대여 (120벌 중 선택)',
      '2회 피팅 포함 (3개월 전 + 1개월 전)',
      '드레스 수선 서비스',
      '피팅 당일 헤어·메이크업 컨설팅',
    ],
    cta: '가격 문의',
    note: '드레스 종류에 따라 가격 상이'
  },
  {
    name: '웨딩 올인원',
    badge: '인기 No.1',
    color: 'border-rose-gold',
    badgeColor: 'bg-rose-gold text-white',
    price: '문의',
    unit: '',
    features: [
      '웨딩드레스 대여 (2회 피팅 포함)',
      '결혼식 당일 헤어·메이크업',
      '도우미 서비스 (1인)',
      '미래웨딩홀 이동 없이 편리하게',
      '피팅 사진 촬영 서비스',
    ],
    cta: '예약 상담',
    note: '가장 많이 선택하는 패키지',
    highlight: true
  },
  {
    name: '헤어·메이크업',
    badge: '단품',
    color: 'border-gray-200',
    badgeColor: 'bg-gray-100 text-gray-600',
    price: '문의',
    unit: '',
    features: [
      '결혼식 당일 헤어스타일링',
      '메이크업 (본식/촬영)',
      '숙련 스탭 5인+ 운영',
      '돌잔치·행사 스타일링 가능',
    ],
    cta: '가격 문의',
    note: '개별 선택 가능'
  }
];
---
<Layout title={title} description={description}>

  <!-- 페이지 헤더 -->
  <section class='py-16 px-4 bg-gradient-to-b from-rose-50 to-white text-center'>
    <p class='text-rose-gold font-medium tracking-[0.3em] text-sm uppercase mb-3'>Packages</p>
    <h1 class='font-display text-4xl md:text-5xl font-bold text-gray-900 mb-4'>패키지 · 가격</h1>
    <p class='text-gray-500 max-w-xl mx-auto'>
      춘천 웨딩마치의 웨딩 서비스 패키지.<br/>
      드레스부터 당일 서비스까지 원스톱으로.
    </p>
  </section>

  <!-- 패키지 카드 -->
  <section class='py-12 px-4'>
    <div class='max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6'>
      {packages.map((pkg) => (
        <div class={}>
          <!-- 배지 -->
          <span class={}>
            {pkg.badge}
          </span>
          
          <h3 class='font-display text-2xl font-bold text-gray-900 mb-2'>{pkg.name}</h3>
          
          <div class='mb-6'>
            <span class='text-3xl font-bold text-rose-gold'>{pkg.price}</span>
            {pkg.unit && <span class='text-gray-500 text-sm ml-1'>{pkg.unit}</span>}
            {pkg.note && <p class='text-xs text-gray-400 mt-1'>{pkg.note}</p>}
          </div>
          
          <ul class='space-y-3 mb-8 flex-grow'>
            {pkg.features.map((feat) => (
              <li class='flex items-start gap-2 text-sm text-gray-600'>
                <span class='text-rose-gold mt-0.5 flex-shrink-0'>✓</span>
                {feat}
              </li>
            ))}
          </ul>
          
          <a href='/contact' 
             class={}>
            {pkg.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- 안내 사항 -->
  <section class='py-12 px-4'>
    <div class='max-w-3xl mx-auto bg-champagne/30 rounded-2xl p-8'>
      <h3 class='font-display text-xl font-bold text-gray-900 mb-4'>예약 안내</h3>
      <ul class='space-y-3 text-sm text-gray-600'>
        <li class='flex items-start gap-2'><span class='text-rose-gold mt-0.5'>•</span>정확한 가격은 드레스 종류 및 서비스 구성에 따라 상이합니다. 상담 후 안내드립니다.</li>
        <li class='flex items-start gap-2'><span class='text-rose-gold mt-0.5'>•</span>1차 피팅: 결혼식 3개월 전 (드레스 3벌 선택)</li>
        <li class='flex items-start gap-2'><span class='text-rose-gold mt-0.5'>•</span>2차 피팅: 결혼식 1개월 전 (최종 드레스 확정)</li>
        <li class='flex items-start gap-2'><span class='text-rose-gold mt-0.5'>•</span>성수기(4~6월, 10~11월)는 일정 조기 마감될 수 있습니다.</li>
        <li class='flex items-start gap-2'><span class='text-rose-gold mt-0.5'>•</span>돌잔치 및 기타 행사 스타일링도 별도 문의 가능합니다.</li>
      </ul>
    </div>
  </section>

  <!-- 하단 CTA -->
  <section class='py-16 px-4 text-center'>
    <p class='text-gray-600 mb-6 text-lg'>궁금한 점이 있으시면 언제든지 문의해주세요</p>
    <a href='/contact' class='inline-block bg-rose-gold text-white px-12 py-4 rounded-full text-lg font-medium hover:bg-deep-rose transition-colors shadow-lg'>
      무료 상담 예약
    </a>
  </section>

</Layout>
