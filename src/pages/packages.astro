---
import Layout from '../layouts/Layout.astro';

const title = '패키지 · 가격 | 웨딩마치 춘천 웨딩드레스';
const description = '춘천 웨딩마치 웨딩 패키지 가격표. 드레스 대여, 헤어·메이크업, 도우미 서비스. 강원도 춘천 웨딩 원스톱 서비스.';

const packages = [
  {
    name: 'Dress Only',
    nameKo: '드레스 패키지',
    badge: 'Essential',
    highlight: false,
    features: [
      '웨딩드레스 대여 (120벌 중 선택)',
      '2회 피팅 포함 (3개월 전 + 1개월 전)',
      '드레스 수선 서비스 포함',
      '피팅 당일 스타일링 컨설팅',
    ],
    cta: '가격 문의',
    note: '드레스 종류에 따라 가격 상이'
  },
  {
    name: 'All-in-One',
    nameKo: '웨딩 올인원',
    badge: 'Most Popular',
    highlight: true,
    features: [
      '웨딩드레스 대여 (2회 피팅 포함)',
      '결혼식 당일 헤어·메이크업',
      '도우미 서비스 (1인)',
      '미래웨딩홀 이동 없이 편리하게',
      '피팅 사진 촬영 서비스',
      '웨딩 당일 전담 스탭 배치',
    ],
    cta: '예약 상담',
    note: '가장 많이 선택하는 패키지'
  },
  {
    name: 'Hair & Make',
    nameKo: '헤어·메이크업',
    badge: 'A la Carte',
    highlight: false,
    features: [
      '결혼식 당일 헤어스타일링',
      '본식 / 촬영 메이크업',
      '숙련 스탭 5인+ 운영',
      '돌잔치·행사 스타일링 가능',
      '개별 선택 및 조합 가능',
    ],
    cta: '가격 문의',
    note: '개별 선택 가능'
  }
];

const faqs = [
  {
    q: '피팅은 언제 진행하나요?',
    a: '1차 피팅은 결혼식 3개월 전, 2차 피팅은 1개월 전에 진행됩니다. 각 피팅 시 3벌씩 착용해보실 수 있습니다.'
  },
  {
    q: '드레스 수선은 포함인가요?',
    a: '기본 수선(기장, 허리 등)은 패키지에 포함됩니다. 대대적인 리폼은 별도 비용이 발생할 수 있습니다.'
  },
  {
    q: '도우미는 어떤 역할을 하나요?',
    a: '결혼식 당일 신부님의 드레스 관리, 트레인 정리, 이동 보조 등 전반적인 웨딩 보조 업무를 담당합니다.'
  },
  {
    q: '성수기 예약은 얼마나 일찍 해야 하나요?',
    a: '4~6월, 10~11월 성수기는 최소 3~6개월 전 예약을 권장합니다. 인기 날짜는 조기 마감됩니다.'
  },
];
---
<Layout title={title} description={description}>

  <!-- 페이지 히어로 -->
  <section class='relative h-56 md:h-72 overflow-hidden'>
    <img src='/images/instagram/08.webp' alt='패키지 헤더' class='w-full h-full object-cover object-center' />
    <div class='absolute inset-0' style='background: linear-gradient(to bottom, rgba(26,16,8,0.5), rgba(26,16,8,0.75));'></div>
    <div class='absolute inset-0 flex flex-col items-center justify-center text-center px-6'>
      <p class='text-white/60 text-xs tracking-[0.5em] uppercase font-light mb-3'>Services & Pricing</p>
      <h1 class='font-display text-4xl md:text-6xl font-light text-white tracking-wider mb-3'>Packages</h1>
      <div class='w-10 h-px bg-white/40'></div>
      <p class='text-white/70 text-sm font-light mt-3'>드레스부터 당일 서비스까지 원스톱으로</p>
    </div>
  </section>

  <!-- 패키지 카드 -->
  <section class='py-20 px-6' style='background: #FAF8F5;'>
    <div class='max-w-6xl mx-auto'>
      <div class='text-center mb-14'>
        <p class='text-xs tracking-[0.5em] text-[#B76E79] uppercase font-light mb-4'>Our Services</p>
        <h2 class='font-display text-4xl font-light text-gray-900 mb-4'>웨딩 서비스 패키지</h2>
        <div class='w-12 h-px bg-[#B76E79] mx-auto'></div>
      </div>

      <div class='grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8'>
        {packages.map((pkg) => (
          <div class={`relative flex flex-col ${pkg.highlight ? 'shadow-2xl scale-[1.02]' : 'shadow-sm hover:shadow-xl'} transition-all duration-500`}>
            <!-- 배지 -->
            {pkg.highlight && (
              <div class='absolute -top-4 left-1/2 -translate-x-1/2 bg-[#B76E79] text-white text-[10px] tracking-[0.3em] uppercase px-5 py-1.5 font-light z-10'>
                {pkg.badge}
              </div>
            )}

            <div class={`flex flex-col h-full border ${pkg.highlight ? 'border-[#B76E79] bg-white' : 'border-[#E8DDD5] bg-white'} p-8 md:p-10`}>
              <!-- 헤더 -->
              <div class='mb-8 pb-6 border-b border-[#E8DDD5]'>
                {!pkg.highlight && (
                  <span class='text-[10px] tracking-[0.3em] text-[#B76E79] uppercase border border-[#D4A0A7] px-2 py-0.5 mb-3 inline-block'>{pkg.badge}</span>
                )}
                <p class='font-display text-3xl font-light text-gray-900 mb-1'>{pkg.name}</p>
                <p class='text-sm text-gray-400 font-light tracking-wide'>{pkg.nameKo}</p>
              </div>

              <!-- 가격 표시 -->
              <div class='mb-8'>
                <div class='flex items-baseline gap-2'>
                  <span class='font-display text-4xl font-light text-[#B76E79]'>문의</span>
                  <span class='text-gray-400 text-sm font-light'>/ 상담 후 안내</span>
                </div>
                {pkg.note && <p class='text-xs text-gray-400 mt-2 font-light'>{pkg.note}</p>}
              </div>

              <!-- 특징 목록 -->
              <ul class='space-y-3 mb-8 flex-grow'>
                {pkg.features.map((feat) => (
                  <li class='flex items-start gap-3 text-sm text-gray-600 font-light'>
                    <span class='text-[#B76E79] mt-0.5 text-xs flex-shrink-0'>✦</span>
                    {feat}
                  </li>
                ))}
              </ul>

              <!-- CTA -->
              <a href='/contact'
                 class={`block text-center py-4 text-xs tracking-[0.3em] uppercase font-light transition-all duration-300 ${pkg.highlight ? 'bg-[#B76E79] text-white hover:bg-[#8B3A47]' : 'border border-[#B76E79] text-[#B76E79] hover:bg-[#B76E79] hover:text-white'}`}>
                {pkg.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 예약 프로세스 -->
  <section class='py-20 px-6' style='background: #1a1008;'>
    <div class='max-w-5xl mx-auto'>
      <div class='text-center mb-14'>
        <p class='text-xs tracking-[0.5em] text-[#D4A0A7] uppercase font-light mb-4'>How It Works</p>
        <h2 class='font-display text-4xl font-light text-white mb-4'>예약 프로세스</h2>
        <div class='w-12 h-px bg-[#D4A0A7] mx-auto'></div>
      </div>

      <div class='grid grid-cols-1 md:grid-cols-4 gap-8'>
        {[
          { step: '01', title: '상담 문의', desc: '인스타 DM 또는 카카오톡으로 문의주세요' },
          { step: '02', title: '1차 피팅', desc: '결혼식 3개월 전 · 드레스 3벌 착용' },
          { step: '03', title: '2차 피팅', desc: '결혼식 1개월 전 · 최종 드레스 확정' },
          { step: '04', title: '결혼식 당일', desc: '헤어·메이크업·도우미 원스톱 서비스' },
        ].map((step) => (
          <div class='text-center'>
            <div class='font-display text-5xl font-light text-[#D4A0A7]/30 mb-3'>{step.step}</div>
            <div class='w-8 h-px bg-[#D4A0A7]/40 mx-auto mb-3'></div>
            <h3 class='text-white text-sm tracking-widest uppercase font-light mb-2'>{step.title}</h3>
            <p class='text-gray-400 text-xs font-light leading-relaxed'>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class='py-20 px-6' style='background: #FAF8F5;'>
    <div class='max-w-3xl mx-auto'>
      <div class='text-center mb-14'>
        <p class='text-xs tracking-[0.5em] text-[#B76E79] uppercase font-light mb-4'>FAQ</p>
        <h2 class='font-display text-4xl font-light text-gray-900 mb-4'>자주 묻는 질문</h2>
        <div class='w-12 h-px bg-[#B76E79] mx-auto'></div>
      </div>

      <div class='space-y-4'>
        {faqs.map((faq, i) => (
          <div class='faq-item bg-white border border-[#E8DDD5] overflow-hidden'>
            <button class='faq-btn w-full flex items-center justify-between px-6 py-5 text-left'
                    data-index={i}>
              <span class='text-sm font-light text-gray-900 tracking-wide'>{faq.q}</span>
              <span class='faq-icon text-[#B76E79] ml-4 flex-shrink-0 transition-transform duration-300'>
                <svg class='w-5 h-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='1' d='M12 6v6m0 0v6m0-6h6m-6 0H6'/>
                </svg>
              </span>
            </button>
            <div class='faq-answer hidden px-6 pb-5'>
              <p class='text-gray-500 text-sm font-light leading-relaxed'>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 하단 CTA -->
  <section class='py-20 px-6 text-center' style='background: #FAF8F5;'>
    <p class='text-gray-400 text-xs tracking-[0.4em] uppercase font-light mb-5'>Ready to Begin?</p>
    <h2 class='font-display text-4xl font-light text-gray-900 mb-4'>무료 상담 예약</h2>
    <div class='w-12 h-px bg-[#B76E79] mx-auto mb-6'></div>
    <p class='text-gray-500 font-light mb-8'>궁금한 점이 있으시면 언제든지 문의해주세요</p>
    <a href='/contact'
       class='inline-block bg-[#B76E79] text-white px-14 py-4 text-xs tracking-[0.3em] uppercase font-light hover:bg-[#8B3A47] transition-colors shadow-lg'>
      지금 문의하기
    </a>
  </section>

</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector<HTMLElement>('.faq-answer')!;
      const icon = btn.querySelector<SVGElement>('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      // 모두 닫기
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(ic => (ic as HTMLElement).style.transform = '');

      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>
