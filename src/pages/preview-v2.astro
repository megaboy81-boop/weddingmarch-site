<!-- ══════════════════════════════════════════════════
     JS
══════════════════════════════════════════════════ -->
<script>
// ── 1. NAV 스크롤 효과 ──────────────────────────
const nav = document.getElementById('v2-nav');
if (nav) {
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
}

// ── 2. 모바일 메뉴 ──────────────────────────────
const menuBtn = document.getElementById('v2-menu-btn') as HTMLButtonElement | null;
const mobileMenu = document.getElementById('v2-mobile-menu');
if (menuBtn && mobileMenu) {
  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
    document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
  });
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
}

// ── 3. 히어로 타이틀 글자 reveal ────────────────
// quentinhocde 스타일: 각 글자가 offset에 따라 다른 translateY에서 0으로
function initHeroReveal() {
  const letters = document.querySelectorAll<HTMLElement>('.v2-letter');
  letters.forEach((letter, i) => {
    const offset = parseInt(letter.style.getPropertyValue('--o') || '1');
    // 딜레이: 각 글자마다 조금씩 다르게
    const delay = 200 + i * 40;
    setTimeout(() => {
      letter.style.transition = `transform ${0.9 + offset * 0.15}s cubic-bezier(0.16,1,0.3,1)`;
      letter.style.transform = 'translateY(0)';
    }, delay);
  });

  // info grid 등장
  const info = document.getElementById('v2-hero-info');
  if (info) {
    setTimeout(() => {
      info.classList.add('visible');
    }, 1200);
  }
}

// ── 4. ScrambleText — 로드 시 타이틀에 적용 ─────
// quentinhocde 핵심 효과: 로드 시 글자들이 랜덤 문자로 바뀌다가 수렴
const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$%*';
function scrambleReveal(el: HTMLElement, finalText: string, startDelay: number) {
  let frame = 0;
  const total = 25;
  setTimeout(() => {
    const id = setInterval(() => {
      el.textContent = finalText.split('').map((ch, idx) => {
        if (ch === ' ') return ' ';
        // 앞에서부터 점진적으로 확정
        if (idx < Math.floor((frame / total) * finalText.length)) return ch;
        return CHARS[Math.floor(Math.random() * CHARS.length)];
      }).join('');
      frame++;
      if (frame > total) {
        el.textContent = finalText;
        clearInterval(id);
      }
    }, 40);
  }, startDelay);
}

// 호버 스크램블 (nav logo, 각 글자)
function initHoverScramble() {
  document.querySelectorAll<HTMLElement>('[data-text]').forEach(el => {
    const original = el.dataset.text || el.textContent || '';
    let isAnimating = false;
    el.addEventListener('mouseenter', () => {
      if (isAnimating) return;
      isAnimating = true;
      scrambleReveal(el, original, 0);
      setTimeout(() => { isAnimating = false; }, 1200);
    });
  });
}

// ── 5. Service item 호버 — 이미지 마우스 추적 ───
function initServiceHover() {
  const items = document.querySelectorAll<HTMLElement>('.v2-service-item');
  items.forEach(item => {
    const preview = item.querySelector<HTMLElement>('.v2-svc-preview');
    if (!preview) return;

    item.addEventListener('mousemove', (e) => {
      preview.style.left = (e.clientX + 20) + 'px';
      preview.style.top = (e.clientY - 170) + 'px';
    });
  });
}

// ── 6. GSAP scroll reveals ───────────────────────
function initGSAP() {
  const gsap = (window as any).gsap;
  const ScrollTrigger = (window as any).ScrollTrigger;
  if (!gsap || !ScrollTrigger) return;

  gsap.registerPlugin(ScrollTrigger);

  // Services 아이템
  gsap.from('.v2-service-item', {
    y: 40, opacity: 0, duration: 0.8, stagger: 0.1, ease: 'power3.out',
    scrollTrigger: { trigger: '.v2-services', start: 'top 75%' }
  });

  // Gallery header
  gsap.from('.v2-gallery-header', {
    y: 24, opacity: 0, duration: 0.9, ease: 'power3.out',
    scrollTrigger: { trigger: '.v2-gallery', start: 'top 80%' }
  });

  // Review cards
  gsap.from('.v2-review-card', {
    y: 32, opacity: 0, duration: 0.8, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '.v2-reviews', start: 'top 78%' }
  });

  // CTA
  gsap.from('.v2-cta-title', {
    y: 36, opacity: 0, duration: 1.1, ease: 'power3.out',
    scrollTrigger: { trigger: '.v2-cta', start: 'top 75%' }
  });
}

// ── 7. Gallery 드래그 ────────────────────────────
function initGalleryDrag() {
  const track = document.getElementById('v2-gal-track') as HTMLElement | null;
  if (!track) return;
  let isDown = false, startX = 0, scrollLeft = 0;

  track.addEventListener('mousedown', e => {
    isDown = true;
    track.style.cursor = 'grabbing';
    startX = e.pageX - track.offsetLeft;
    scrollLeft = track.scrollLeft;
    e.preventDefault();
  });
  ['mouseleave', 'mouseup'].forEach(ev => {
    track.addEventListener(ev, () => {
      isDown = false;
      track.style.cursor = 'grab';
    });
  });
  track.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    track.scrollLeft = scrollLeft - (e.pageX - track.offsetLeft - startX) * 1.6;
  });
  track.style.cursor = 'grab';
}

// ── INIT ────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  initHeroReveal();
  initHoverScramble();
  initServiceHover();
  initGalleryDrag();
  // GSAP: 짧은 딜레이 후 (CDN 로드 대기)
  setTimeout(initGSAP, 500);
});
</script>

</Layout>
